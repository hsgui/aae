{
  "name": "@hsgui/aae",
  "version": "0.5.0",
  "description": "AI Agent Engineering — Install and manage skills, agents, hooks, and workflows for AI coding assistants.",
  "type": "module",
  "bin": {
    "aae": "bin/aae.js"
  },
  "main": "./src/index.mjs",
  "exports": {
    ".": "./src/index.mjs",
    "./skills/*": "./skills/*",
    "./commands/*": "./commands/*",
    "./agents/*": "./agents/*",
    "./hooks/*": "./hooks/*",
    "./workflows/*": "./workflows/*"
  },
  "files": [
    "bin/",
    "src/",
    "skills/",
    "commands/",
    "agents/",
    "hooks/",
    "workflows/"
  ],
  "scripts": {
    "postinstall": "node bin/aae.js link --quiet",
    "test": "node --test src/**/*.test.mjs"
  },
  "keywords": [
    "ai",
    "agent",
    "cursor",
    "claude",
    "claude-code",
    "skills",
    "commands",
    "hooks",
    "workflows",
    "coding-assistant",
    "aae"
  ],
  "author": "",
  "license": "MIT",
  "engines": {
    "node": ">=18"
  }
}
